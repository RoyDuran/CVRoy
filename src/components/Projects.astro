<section id="projects">
  <h3 >Proyectos</h3>
    {
      projects.map((project) => (
        <div class="bg-white p-2 rounded-lg shadow-lg
            hover:scale-110
            transition-all
            duration-300 mb-2 fade-up">
        <h4><a href={project.url} target="_blank">{project.title}</a></h4>
        <p class="text-gray-500">{project.fecha}</p>
        <p>{project.description}</p>
        <p class="text-gray-600">Tecnologias: {project.tecnologias}</p>
        </div>
      ))
    }
  </div>
</section>
